# =============================================================================
# DISCOBASE BOT CONFIGURATION
# =============================================================================

# Bot Credentials (Required)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
BOT_ID=YOUR_BOT_ID_HERE
OWNER_ID=YOUR_OWNER_ID_HERE

# Bot Prefix (Optional, defaults to !)
BOT_PREFIX=!

# MongoDB Database URL (Optional)
MONGODB_URL=YOUR_MONGODB_URL_HERE

# Error Logging Webhook URL (Optional)
ERROR_WEBHOOK_URL=YOUR_ERROR_WEBHOOK_URL_HERE

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Admin User IDs (comma-separated)
# ADMIN_IDS=123456789012345678,876543210987654321

# Developer Server IDs (comma-separated)
# DEV_SERVER_IDS=123456789012345678

# Guild Log Channel IDs
# GUILD_JOIN_LOGS_ID=123456789012345678
# GUILD_LEAVE_LOGS_ID=123456789012345678
# COMMAND_LOGS_CHANNEL_ID=123456789012345678
